---
// Import the necessary dependencies
import enStrings from "@utils/navigation.ts";
import FooterLogo from "@components/FooterLogo.astro";
import FooterSocialLink from "@components/ui/links/FooterSocialLink.astro";
import Icon from "@components/ui/icons/Icon.astro";

// Define interfaces that match the exact structure from navigation.ts
interface FooterLink {
  name: string;
  url: string;
}

interface FooterSection {
  section: string;
  links: FooterLink[];
}

// Remove language selection and just use English strings
const strings = enStrings;

const tagline: string =
  "Websites for local businesses across Australia, designed and built in Melbourne.";
const contactEmail: string = "hello@damontana.com.au";
---

<footer class="w-full bg-[#1A468E]">
  <div
    class="mx-auto w-full max-w-[85rem] px-4 py-10 sm:px-6 lg:px-16 lg:pt-20 2xl:max-w-(--breakpoint-2xl)"
  >
    <div class="grid grid-cols-2 gap-6 sm:grid-cols-3">
      <div class="col-span-full sm:col-span-1">
        <!-- Brand Logo -->
        <FooterLogo class="h-auto w-56" />
        <p class="mt-3 max-w-xs text-sm text-white/80">
          {tagline}
        </p>
      </div>
      <!-- An array of links for Work and Get in touch sections -->
      {
        strings.footerLinks.map((section: FooterSection) => (
          <div class="col-span-1">
            <h4 class="font-semibold text-white">
              {section.section}
            </h4>

            <div class="mt-3 grid space-y-3">
              {
                section.links.map((link: FooterLink) => (
                  <p>
                    <a
                      class="text-white hover:text-white/80"
                      href={link.url}
                    >
                      {link.name}
                    </a>
                  </p>
                ))
              }
              {
                section.section === "Get in touch" && (
                  <p>
                    <a
                      class="text-white hover:text-white/80"
                      href={`mailto:${contactEmail}`}
                    >
                      {contactEmail}
                    </a>
                  </p>
                )
              }
            </div>
          </div>
        ))
      }
    </div>

    <div
      class="mt-9 grid gap-y-2 sm:mt-12 sm:flex sm:items-center sm:justify-between sm:gap-y-0"
    >
      <p class="text-sm text-white/80">
        © <span id="current-year"></span> David Montana · Melbourne, Australia
      </p>

      <!-- Social Brands -->
      <div>
        <FooterSocialLink url={strings.socialLinks.behance}
          ><Icon name="behanceFooter" />
        </FooterSocialLink>

        <FooterSocialLink url={strings.socialLinks.instagram}
          ><Icon name="instagramFooter" />
        </FooterSocialLink>

        <FooterSocialLink url={strings.socialLinks.dribbble}
          ><Icon name="dribbbleFooter" />
        </FooterSocialLink>

        <FooterSocialLink url={strings.socialLinks.linkedin}
          ><Icon name="linkedinFooter" />
        </FooterSocialLink>

        <FooterSocialLink url={strings.socialLinks.github}
          ><Icon name="githubFooter" />
        </FooterSocialLink>
      </div>
    </div>

    <script>
      const year = new Date().getFullYear();
      const element = document.getElementById("current-year");
      element!.innerText = year.toString();
    </script>
  </div>
</footer>

<!-- Copyright Bar -->
<div class="w-full bg-[#0F172A] py-4">
  <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm text-white/60">
      All rights reserved. Built with precision and care.
    </p>
  </div>
</div>
