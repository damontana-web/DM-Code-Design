---
// A simple numbered 3-step process section — no imagery, just the steps.
const { title, subTitle, steps } = Astro.props;

interface Step {
  heading: string;
  content: string;
}

interface Props {
  title?: string;
  subTitle?: string;
  steps: Step[];
}
---

<section
  class="mx-auto max-w-[85rem] px-4 py-30 sm:px-6 lg:px-8 2xl:max-w-full"
>
  <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-16">
    <h2 class="text-balance text-2xl text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
      {title}
    </h2>
    {
      subTitle && (
        <p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">
          {subTitle}
        </p>
      )
    }
  </div>

  <div class="grid gap-10 sm:grid-cols-3 sm:gap-6 lg:gap-12">
    {
      steps.map((step, index) => (
        <div class="flex flex-col gap-y-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-full bg-magenta-500/[0.1] text-lg font-bold text-magenta-500">
            {index + 1}
          </span>
          <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">
            {step.heading}
          </h3>
          <p class="text-pretty text-neutral-600 dark:text-neutral-400">
            {step.content}
          </p>
        </div>
      ))
    }
  </div>
</section>
