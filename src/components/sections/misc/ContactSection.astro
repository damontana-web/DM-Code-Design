---
// Import the necessary dependencies.
import AuthBtn from "@components/ui/buttons/AuthBtn.astro";
import ContactIconBlock from "@components/ui/blocks/ContactIconBlock.astro";
import TextInput from "@components/ui/forms/input/TextInput.astro";
import EmailContactInput from "@components/ui/forms/input/EmailContactInput.astro";
import PhoneInput from "@components/ui/forms/input/PhoneInput.astro";
import TextAreaInput from "@components/ui/forms/input/TextAreaInput.astro";
import Icon from "@components/ui/icons/Icon.astro";

// Define the variables that will be used in this component
const title: string = "Let's talk about your project";
const subTitle: string =
  "Whether you've got a full brief or just a rough idea, send it through. I'll come back with my honest take on what I'd do and roughly what it would cost — no obligation, no hard sell.";
const formTitle: string = "Tell me a bit about it";
const formSubTitle: string = "I reply within 1–2 business days.";
const contactEmail: string = "hello@damontana.com.au";
---

<!-- Contact Us -->
<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1
        class="text-balance text-2xl tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        {title}
      </h1>
      <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>

    <div class="mt-12 grid items-center gap-6 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col rounded-xl p-4 sm:p-6 lg:p-8">
        <h2
          class="mb-8 text-xl font-bold text-neutral-700 dark:text-neutral-300"
        >
          {formTitle}
        </h2>
        <!-- Form for user input with various input fields.-->
        <!-- Each field utilizes a different input component for the specific type of input (text, email, phone, and textarea)-->
        <form>
          <div class="grid gap-4">
            <TextInput
              id="hs-firstname-contacts"
              label="First Name"
              name="hs-firstname-contacts"
            />
            <EmailContactInput id="hs-email-contacts" />
            <PhoneInput id="hs-phone-number" label="Phone (optional)" />
            <TextAreaInput
              id="hs-about-contacts"
              label="Message"
              name="hs-about-contacts"
              placeholder="What does your business do, and what do you need? Rough is fine."
            />
          </div>

          <div class="mt-4 grid">
            <AuthBtn title="Send message" />
          </div>

          <div class="mt-3 text-center">
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
              {formSubTitle}
            </p>
          </div>
        </form>
      </div>

      <!--ContactIconBlocks cover the other ways to get in touch: email, FAQ, location, and agency enquiries.-->
      <div class="divide-y divide-neutral-300 dark:divide-neutral-700">
        <ContactIconBlock
          heading="Prefer email?"
          content={`No forms necessary — write to me directly at`}
          isLinkVisible={true}
          linkTitle={contactEmail}
          linkURL={`mailto:${contactEmail}`}
          ><Icon name="envelopeOpen" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Common questions"
          content="Costs, timelines, and what happens after launch — most of it's answered here."
          isLinkVisible={true}
          linkTitle="Read the FAQ"
          linkURL="/#faq"
          isArrowVisible={true}
          ><Icon name="chatBubble" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Based in Melbourne"
          content="I work with businesses across Australia. Happy to meet in person if you're local, or over a call if you're not."
          ><Icon name="mapPin" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Agencies and studios"
          content="Looking for white-label design or development support? Mention it in your message and I'll send through how I usually work with agencies."
          ><Icon name="community" />
        </ContactIconBlock>
      </div>
    </div>
  </div>
</section>
