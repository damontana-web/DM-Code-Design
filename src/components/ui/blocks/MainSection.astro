---
// Import PrimaryCTA component
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import HeadingIcon from "@components/ui/icons/HeadingIcon.astro";

// Destructure the props passed to the Astro component
const { title, subTitle, btnExists, btnTitle, btnURL, icon } = Astro.props;
// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  icon?: string | string[];
}
---

<!-- Root section of the component -->
<section
  class="mx-auto mt-10 max-w-[85rem] px-4 py-8 sm:px-6 sm:py-12 lg:px-8 lg:py-10 2xl:max-w-full"
>
  <div class="mx-auto max-w-(--breakpoint-md) text-center">
    <!-- Section title -->
    <h1
      class="mb-4 flex items-center justify-center gap-2 text-balance text-2xl tracking-tight text-gray-700 md:text-4xl md:leading-tight"
    >
      {icon && <HeadingIcon d={icon} size="1.5em" flexAlign />}{title}
    </h1>
    <!-- Section subtitle -->
    <p
      class="mb-8 mt-1 text-pretty text-neutral-600 dark:text-neutral-400"
    >
      {subTitle}
    </p>
    <!-- Conditional rendering of PrimaryCTA component if 'btnExists' property is truthy -->
    {
      btnExists ? (
        <div class="flex flex-col justify-center space-y-4 sm:flex-row sm:space-x-4 sm:space-y-0">
          <PrimaryCTA title={btnTitle} url={btnURL} />
        </div>
      ) : null
    }
  </div>
</section>
