---
// Importing necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import CardSmall from "@components/ui/cards/CardSmall.astro";
import CardWide from "@components/ui/cards/CardWide.astro";
import FeaturesStatsAlt from "@components/sections/features/FeaturesStatsAlt.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import HeadingIcon from "@components/ui/icons/HeadingIcon.astro";

// Importing necessary functions from Astro
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";

// Fetching all the product related content and sorting it by main.id
const product: CollectionEntry<"products">[] = (
  await getCollection("products", ({ id }) => {
    return id.startsWith("en/");
  })
).sort(
  (a: CollectionEntry<"products">, b: CollectionEntry<"products">) =>
    a.data.main.id - b.data.main.id,
);

// Define variables for page content
const title: string = "Work";
const subTitle: string =
  "Recent projects: websites, rebrands, and platform builds for businesses of all sizes, from local clinics to government departments. Some I designed and built solo, start to finish. On others I worked as part of a larger team.";

const pageTitle: string = "Work | DaMontana Design + Code";
const pageDescription: string =
  "Recent websites, rebrands and builds for small businesses across Australia — each one designed and coded by me, start to finish.";
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${SITE.url}/portfolio`,
    "url": `${SITE.url}/portfolio`,
    "name": pageTitle,
    "description": pageDescription,
    "isPartOf": {
      "@type": "WebSite",
      "url": SITE.url,
      "name": SITE.title,
      "description": SITE.description
    },
    "inLanguage": "en-US"
  }}
>
  <div
    class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
  >
    <div class="mx-auto mt-10 max-w-3xl text-center">
      <h1
        class="mb-4 flex items-center justify-center gap-2 text-balance text-2xl tracking-tight text-gray-700 md:text-4xl md:leading-tight"
      >
        <HeadingIcon
          d="M2 8h2v12H2zm18 0h2v12h-2zM4 6h16v2H4zm0 14h16v2H4zM8 4h2v2H8zm2-2h4v2h-4zm4 2h2v2h-2z"
          size="1.5em"
          flexAlign
        />{title}
      </h1>
      {
        subTitle && (
          <p class="mb-8 mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
            {subTitle}
          </p>
        )
      }
    </div>
    <!--Displaying products in alternating styles. Alternative product gets different card styling.-->
    <!--Maps through all product entries and displays them with either CardSmall or CardWide based on their position.-->
    <section class="grid grid-cols-1 gap-4 sm:grid-cols-3 md:gap-6 xl:gap-8">
      {
        product.map((product, index) => {
          const position = index % 4;
          if (position === 0 || position === 3) {
            return <CardSmall product={product} />;
          } else {
            return <CardWide product={product} />;
          }
        })
      }
    </section>
  </div>
  <!--How these projects get built-->
  <FeaturesStatsAlt
    title="How these get built"
    subTitle="My process is the same whether I'm working solo or inside a team: design in Figma first, get it approved, then code. What I design is what I build."
    benefits={[
      "Hands-on across design and development. I don't just direct, I build.",
      "Built on WordPress, a modern lightweight setup, or a fully custom platform, whichever suited the project.",
      "Fast, mobile-friendly, and owned entirely by the client.",
    ]}
  />
  <!--Closing CTA-->
  <HeroSectionAlt
    title="Want something like this for your business?"
    subTitle="Tell me what you're after, or just what's not working with your current site, and I'll tell you how I'd approach it."
    btnTitle="Book a call"
    url="/contact"
  />
</MainLayout>
