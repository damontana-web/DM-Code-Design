---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import Icon from "@components/ui/icons/Icon.astro";
import HeadingIcon from "@components/ui/icons/HeadingIcon.astro";
import { SITE } from "@data/constants";

import personWorking from "@images/person-working.avif";
import dashboardImage from "@images/dashboard-image.avif";

const pageTitle: string = "About | DaMontana Design + Code, Melbourne";
const pageDescription: string =
  "Designer and developer with agency roots — Young & Rubicam, Cannes Lions — now building websites for small businesses across Australia.";
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${SITE.url}/about`,
    "url": `${SITE.url}/about`,
    "name": pageTitle,
    "description": pageDescription,
    "isPartOf": {
      "@type": "WebSite",
      "url": SITE.url,
      "name": SITE.title,
      "description": SITE.description,
    },
    "inLanguage": "en-US",
  }}
>
  <!-- Hero -->
  <MainSection
    title="About"
    subTitle="I'm David Montana — a designer and developer in Melbourne. I've spent 15 years building websites and brands, first inside big agencies, then independently as DaMontana. Here's the short version of how I got here and how I work."
  />

  <!-- Section 1 — Trained as a designer first -->
  <RightSection
    title="Trained as a designer first"
    subTitle="I studied Graphic Design, specialising in illustration and digital marketing — which is a long way of saying I learned to think about how things look, how they persuade, and how they work, all at once. The code came later, and it came from necessity: I kept designing things and wanting them built properly."
    single={true}
    imgOne={personWorking}
    imgOneAlt="Person working at a desk"
    icon="M8 20h6v-2h2v2h4v2H4v-2h2v-2h2v2Zm-4 0H2V4h2v16Zm18 0h-2v-4h-2v-2h2V4h2v16Zm-12-2H8v-2h2v2Zm4 0h-2v-2h2v2Zm-2-2h-2v-2h2v2Zm4 0h-2v-2h2v2Zm2-2h-2v-2h2v2Zm-8-2H8v-2h2v2Zm-2-2H6V8h2v2Zm4 0h-2V8h2v2Zm-2-2H8V6h2v2Zm10-4H4V2h16v2Z"
  />

  <!-- Section 2 — The agency years -->
  <LeftSection
    title="The agency years"
    subTitle="Early in my career I worked inside advertising and creative agencies, including Young & Rubicam — one of the biggest names in the industry. Agency work teaches you two things fast: how to deliver at a professional standard under real deadlines, and how big-brand thinking actually works. Along the way, my work picked up awards at Cannes Lions (Young Lions competition) and FIAP, the Ibero-American advertising festival."
    img={dashboardImage}
    imgAlt="Screen mockup representing creative work"
    icon="M15 22H9v-6h6v6Zm-4-2h2v-2h-2v2Zm-2-4H7v-2h2v2Zm8 0h-2v-2h2v2ZM7 14H5V8h2v6Zm12 0h-2V8h2v6ZM3 12H0v-2h3v2Zm21 0h-3v-2h3v2ZM9 8H7V6h2v2Zm8 0h-2V6h2v2ZM5 6H3V4h2v2Zm10 0H9V4h6v2Zm6 0h-2V4h2v2ZM3 4H1V2h2v2Zm20 0h-2V2h2v2ZM13 3h-2V0h2v3Z"
  />

  <!-- Section 3 — Then I went out on my own -->
  <RightSection
    title="Then I went out on my own"
    subTitle="For the past 15 years I've worked independently as DaMontana, mostly with small and medium businesses — real estate agencies, clinics, suppliers, local companies. It turns out the thing I like most isn't big-brand campaigns. It's taking that agency-level standard and applying it where it's rare: businesses that usually can't get it without paying agency prices or dealing with agency layers. I still work with agencies too — as an external designer and developer when their workload spikes — so I keep a foot in both worlds. Your project gets the discipline of one and the directness of the other."
    single={true}
    imgOne={personWorking}
    imgOneAlt="Person working independently at a desk"
    icon="M17 9h-2v13h-2v-6h-2v6H9V9H7V7h10v2Zm-6 5h2V9h-2v5ZM7 7H5V5h2v2Zm12 0h-2V5h2v2Zm-5-1h-4V2h4v4ZM5 5H3V3h2v2Zm16 0h-2V3h2v2Z"
  />

  <!-- Section 4 — What that means for you -->
  <LeftSection
    title="What that means for you"
    subTitle="Everything on this site comes from those years: design in Figma first so you see it before it's built, code it myself so nothing gets lost in handover, explain everything in plain English because most of my clients aren't web people — and shouldn't have to be."
    img={dashboardImage}
    imgAlt="Screen mockup representing a finished website"
    icon="M20 22H4v-2h16v2ZM4 20H2V4h2v16ZM18 4h-2v2h2V4h2v2h2v14h-2V8h-6V4H4V2h14v2Zm-4 14h-4v-2h4v2Zm-4-2H8v-2h2v2Zm6 0h-2v-2h2v2Zm-6-4H8v-2h2v2Zm6 0h-2v-2h2v2Z"
    btnExists={true}
    btnTitle="See my work"
    btnURL="/portfolio"
  />

  <!-- Recognition -->
  <section class="mx-auto max-w-[85rem] px-4 pb-10 sm:px-6 lg:px-8 lg:pb-14">
    <div
      class="mx-auto max-w-3xl rounded-xl border border-neutral-200 p-6 dark:border-neutral-700"
    >
      <h3 class="font-bold text-blue-darkest">
        <HeadingIcon d="M16 17h-3v2h2v2H9v-2h2v-2H8v-2h8v2Zm2-12h4v6h-2V7h-2v4h2v2h-2v2h-2V5H8v10H6v-2H4v-2h2V7H4v4H2V5h4V3h12v2Z" />Recognition
      </h3>
      <ul class="mt-3 space-y-2">
        <li class="flex items-start gap-1.5 text-neutral-600 dark:text-neutral-400">
          <Icon name="checkCircle" />
          <span>
            <strong class="text-neutral-800 dark:text-neutral-200">Cannes Lions</strong>
            — Young Lions competition (Absolut Vodka)
          </span>
        </li>
        <li class="flex items-start gap-1.5 text-neutral-600 dark:text-neutral-400">
          <Icon name="checkCircle" />
          <span>
            <strong class="text-neutral-800 dark:text-neutral-200">FIAP</strong>
            — Young Creatives Awards (MTV Networks)
          </span>
        </li>
      </ul>
    </div>

    <p class="mx-auto mt-8 max-w-3xl text-pretty italic text-neutral-600 dark:text-neutral-400">
      When I'm not building websites, I'm usually painting or behind a
      camera — the design eye doesn't switch off.
    </p>
  </section>

  <!-- Closing CTA -->
  <HeroSectionAlt
    title="Working on something?"
    subTitle="Tell me about your business and what you're trying to do — I'll give you an honest read on how I'd approach it."
    btnTitle="Book a call"
    url="/contact"
  />
</MainLayout>
