---
// Import necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";

// Import necessary images
import blueprints from "@images/blueprints-image.avif";
import personWorking from "@images/person-working.avif";
import dashboardImage from "@images/dashboard-image.avif";
import { SITE } from "@data/constants";

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: "Design you can see before it's built",
    subTitle:
      "Every project starts in Figma. You'll see full designs of your site — and can click through a working prototype — before I write a single line of code. That means feedback happens early, when changes are quick and cheap, not after everything's been built. By the time development starts, there are no surprises left.",
    single: false,
    imgOne: blueprints,
    imgOneAlt: "Blueprints and digital tablet with construction plans.",
    imgTwo: personWorking,
    imgTwoAlt: "Person working in the office",
  },
  {
    isRightSection: false,
    title: "Built on the right platform for you",
    subTitle:
      "Once the design's approved, I build it — on WordPress if you want to manage content yourself, or a modern lightweight setup if speed and low maintenance matter more. That choice depends on how you'll actually use the site, and it's a conversation we have before anything starts. Either way, the site is fast, works properly on phones, and belongs entirely to you.",
    img: dashboardImage,
    imgAlt: "Screen mockup of a finished website",
    btnExists: true,
    btnTitle: "See recent work",
    btnURL: "/products",
  },
  {
    isRightSection: true,
    title: "A look that carries across everything",
    subTitle:
      "Your website is one piece of a bigger picture. I design logos, colour palettes, and brand guidelines that work everywhere your business shows up — the site, your socials, your signage, your invoices. If you already have a brand, I'll work within it. If you don't, we can build one that suits the business you actually run.",
    single: true,
    imgOne: dashboardImage,
    imgOneAlt: "Screen mockup of a designed website",
  },
  {
    isRightSection: false,
    title: "Support that doesn't end at launch",
    subTitle:
      "Websites need occasional attention — updates, small changes, the odd thing that breaks. Every project includes a handover so you can manage the basics yourself, plus a few weeks of post-launch support. If you'd rather not touch it at all, I offer a monthly retainer: set fee, no lock-in contracts, and things get faster over time as I get to know your business.",
    img: personWorking,
    imgAlt: "Person working at a desk",
  },
  {
    isRightSection: true,
    title: "White-label support for agencies and studios",
    subTitle:
      "I also work as an external designer and developer for creative and digital agencies — Figma-to-code builds, front-end development, or overflow capacity when the workload spikes. I've spent years embedded in agency workflows, so I'm comfortable with your tools, your processes, and your client deadlines. Your clients deal with you; I make you look good.",
    single: false,
    imgOne: blueprints,
    imgOneAlt: "Wireframes and project planning documents",
    imgTwo: dashboardImage,
    imgTwoAlt: "Screen mockup representing agency handoff work",
    btnExists: true,
    btnTitle: "Get in touch",
    btnURL: "/contact",
  },
];

const pageTitle: string =
  "Web Design, Development & Branding Services | DaMontana";
const pageDescription: string =
  "Web design, development, branding and ongoing support for small businesses — plus white-label help for agencies. Designed in Figma, built to last.";
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${SITE.url}/services`,
    "url": `${SITE.url}/services`,
    "name": pageTitle,
    "description": pageDescription,
    "isPartOf": {
        "@type": "WebSite",
        "url": SITE.url,
        "name": SITE.title,
        "description": SITE.description
    },
    "inLanguage": "en-US"
  }}
>
  <!--MainSection is the introductory section of the page, it also contains a CTA button-->
  <MainSection
    title="What I can do for your business"
    subTitle="Every project is different, but the approach is the same: understand what your business actually needs, design it properly, build it well, and stay available afterwards. Here's what that covers."
    btnExists={true}
    btnTitle="Book a call"
    btnURL="/contact"
  />
  <!-- RightSection and LeftSection contain details about various services along with pertinent imagery.
  They alternate for variety in design.
  The 'btnExists' property is used to toggle the display of a button in these sections.
  When btnExists={true}, a button is displayed.
  This can be used to link to more detailed information or related resources.
  RightSection can also conditionally render one or two images based on the 'single' property.
  If 'single' is true, it displays one image, otherwise it displays two.
  -->
  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
  <!--Closing CTA-->
  <HeroSectionAlt
    title="Not sure which of these you need?"
    subTitle="That's normal — most people aren't sure until we talk it through. Book a call, tell me what's going on with your business, and I'll tell you what I'd do."
    btnTitle="Book a call"
    url="/contact"
  />
</MainLayout>
