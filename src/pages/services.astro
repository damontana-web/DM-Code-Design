---
// Import necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";

// Import necessary images
import designImage from "@images/services-design.jpg";
import designImage2 from "@images/services-design-2.jpg";
import platformImage from "@images/services-platform.jpg";
import platformImage2 from "@images/services-platform-2.jpg";
import brandingImage from "@images/services-branding.jpg";
import brandingImage2 from "@images/services-branding-2.jpg";
import supportImage from "@images/services-support.jpg";
import whiteLabelImage from "@images/services-white-label.jpg";
import whiteLabelImage2 from "@images/services-white-label-2.jpg";
import { SITE } from "@data/constants";

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
  icon?: string | string[];
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: "Design you can see before it's built",
    subTitle:
      "Every project starts in Figma. You will see full designs before a single line of code is written.",
    single: false,
    imgOne: designImage,
    imgOneAlt: "Design work in progress",
    imgTwo: designImage2,
    imgTwoAlt: "Design campaign mockups",
    icon: "M4 16H6V18H8V20H10V22H2V14H4V16ZM12 20H10V18H12V20ZM14 18H12V16H14V18ZM10 16H8V14H10V16ZM16 16H14V14H16V16ZM6 14H4V12H6V14ZM12 14H10V12H12V14ZM18 14H16V12H18V14ZM8 12H6V10H8V12ZM14 12H12V10H14V12ZM20 12H18V10H20V12ZM10 10H8V8H10V10ZM18 10H16V8H18V10ZM22 10H20V8H22V10ZM12 8H10V6H12V8ZM16 8H14V6H16V8ZM20 8H18V6H20V8ZM14 6H12V4H14V6ZM18 6H16V4H18V6ZM16 4H14V2H16V4Z",
  },
  {
    isRightSection: false,
    title: "Built on the right platform for you",
    subTitle:
      "WordPress if you want to manage content yourself, or a modern lightweight setup for speed and low maintenance.",
    img: platformImage,
    imgAlt: "Screen mockup of a finished website",
    imgTwo: platformImage2,
    imgTwoAlt: "Screen mockup of a platform build",
    btnExists: true,
    btnTitle: "See my work",
    btnURL: "/portfolio",
    icon: "M20 22H4v-2h16v2ZM4 20H2V4h2v16Zm18 0h-2V4h2v16ZM8 18H6v-2h2v2Zm8 0h-4v-2h4v2Zm-6-2H8v-2h2v2Zm-2-2H6v-2h2v2ZM20 4H4V2h16v2Z",
  },
  {
    isRightSection: true,
    title: "A look that carries across everything",
    subTitle:
      "Your website is just one piece of the puzzle. I can create design systems, colour palettes, typography, and brand guidelines that work across every touchpoint.",
    single: false,
    imgOne: brandingImage,
    imgOneAlt: "Healthscope branded event promotion design",
    imgTwo: brandingImage2,
    imgTwoAlt: "Brand identity mockups",
    icon: "M9 11h2v2H9zm4 0h2v2h-2zM7 7h10v2H7zM5 9h2v6H5zm2 6h10v2H7zm10-6h2v6h-2zm-6-4h2v2h-2zM4 2h4v2H4zm0 18h4v2H4zM16 2h4v2h-4zm0 18h4v2h-4zM2 4h2v4H2zm0 12h2v4H2zM20 4h2v4h-2zm0 12h2v4h-2z",
  },
  {
    isRightSection: false,
    title: "Support that doesn't end at launch",
    subTitle:
      "Updates, improvements, fixes, and ongoing assistance after launch.",
    img: supportImage,
    imgAlt: "Person working at a desk",
    icon: "M13 16h2v4h2v2H7v-2h2v-4h2v-2h2v2Zm-6 4H5v-2h2v2Zm12 0h-2v-2h2v2ZM5 18H3v-8h2v8Zm16 0h-2v-6h2v6Zm-6-6h-2v-2h2v2Zm4 0h-2v-2h2v2ZM7 10H5V8h2v2Zm6 0h-2V6h2v4Zm4 0h-2V8h2v2ZM9 8H7V6h2v2Zm2-2H9V2h2v4Z",
  },
  {
    isRightSection: true,
    title: "White-label support for agencies and studios",
    subTitle:
      "Design and development support for creative and digital agencies, from Figma-to-code work through to overflow production projects.",
    single: false,
    imgOne: whiteLabelImage,
    imgOneAlt: "Healthscope campaign design library in Figma",
    imgTwo: whiteLabelImage2,
    imgTwoAlt: "Healthscope campaign templates in Figma",
    btnExists: true,
    btnTitle: "Get in touch",
    btnURL: "/contact",
    icon: "M6 2h12v2H6zM4 4h2v18H4zm14 0h2v18h-2zm-2 16h2v2h-2zm-2-2h2v2h-2zm-8 2h2v2H6zm2-2h2v2H8zm2-2h4v2h-4z",
  },
];

const pageTitle: string =
  "Web Design, Development & Branding Services | DaMontana";
const pageDescription: string =
  "Web design, development, branding and ongoing support for small businesses — plus white-label help for agencies. Designed in Figma, built to last.";
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${SITE.url}/services`,
    "url": `${SITE.url}/services`,
    "name": pageTitle,
    "description": pageDescription,
    "isPartOf": {
        "@type": "WebSite",
        "url": SITE.url,
        "name": SITE.title,
        "description": SITE.description
    },
    "inLanguage": "en-US"
  }}
>
  <!--MainSection is the introductory section of the page, it also contains a CTA button-->
  <MainSection
    title="What I can do for your business"
    subTitle="Every project is different, but the approach is always the same. I figure out what your business needs, design it properly, build it well, and stay available afterwards."
    icon="M3 23H1v-2h2v2Zm10 0h-2v-3h2v3Zm10 0h-2v-2h2v2ZM5 21H3v-2h2v2Zm16 0h-2v-2h2v2Zm-9-5h4v2H8v-2h2v-2h2v2Zm-4 0H6V8h2v8Zm10 0h-2v-4h-2v-2h2V8h2v8Zm-4-2h-2v-2h2v2ZM4 13H1v-2h3v2Zm19 0h-3v-2h3v2Zm-12-2H9V9h2v2Zm5-3H8V6h8v2ZM5 5H3V3h2v2Zm16 0h-2V3h2v2Zm-8-1h-2V1h2v3ZM3 3H1V1h2v2Zm20 0h-2V1h2v2Z"
    btnExists={true}
    btnTitle="Book a call"
    btnURL="/contact"
  />
  <!-- RightSection and LeftSection contain details about various services along with pertinent imagery.
  They alternate for variety in design.
  The 'btnExists' property is used to toggle the display of a button in these sections.
  When btnExists={true}, a button is displayed.
  This can be used to link to more detailed information or related resources.
  RightSection can also conditionally render one or two images based on the 'single' property.
  If 'single' is true, it displays one image, otherwise it displays two.
  -->
  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
          icon={article.icon}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
          icon={article.icon}
        />
      );
    })
  }
  <!--Closing CTA-->
  <HeroSectionAlt
    title="Not sure which of these you need?"
    subTitle="Book a call and we will talk it through."
    btnTitle="Book a call"
    url="/contact"
  />
</MainLayout>
