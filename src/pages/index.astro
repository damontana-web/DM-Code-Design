---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import RecentWork from "@components/sections/work/RecentWork.astro";
import PricingSection from "@components/sections/pricing/PricingSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import heroImage from "@images/HeroImage.png";
import faqs from "@data/faqs.json";
import features from "@data/features.json";
import pricing from "@data/pricing.json";
import personWorking from "@images/person-working.avif";
import dashboard from "@images/dashboard-image.avif";
import progressBuilding from "@images/progress-building.avif";

const pageTitle: string =
  "DaMontana Design + Code | Web Designer & Developer, Melbourne";
const pageDescription: string =
  "Melbourne web designer and developer for small businesses. Design + code by one person, start to finish — no handovers, no agencies.";
---

<MainLayout title={pageTitle} meta={pageDescription}>
  <AnnouncementBanner
    btnId="dismiss-button"
    btnTitle="Explore DaMontana Code + Design on GitHub"
    url="https://github.com/mearashadowfax/ScrewFast"
  />

  <HeroSection
    title=`<span class="text-magenta-500">{Design}</span> that hits your audience. + Clean <span class="text-blue-primary">{Code}</span> that just works.`
    subTitle="Hi, I'm David Montana, a Melbourne designer and developer. For the past 15 years I've built websites for real estate agencies, clinics, and local businesses across Australia."
    primaryBtn="Tell me about your project"
    primaryBtnURL="/contact"
    secondaryBtn="See my work"
    secondaryBtnURL="/products"
    src={heroImage}
    alt="David Montana - UX/UI Designer and Front-end Developer"
  />

  <FeaturesGeneral
    title="What I Do"
    subTitle="I take care of both design and development personally. There's no handover between teams, so what you approve in the design is exactly what gets built."
    features={features}
  />

  <FeaturesNavs
    title="How I work"
    subTitle="I trained inside big advertising agencies and have spent years working with digital studios as an external designer and developer, so I run a proper process — clear scope, honest timelines, no surprises. But most of my direct clients aren't web people, and they shouldn't have to be. My job is to ask the right questions and explain everything in plain English."
    tabs={[
      {
        heading: "We start with a conversation",
        content:
          "Book a call and tell me about your business — what's working, what isn't, and what you're trying to achieve. I'll give you my honest read on what I'd do, how long it would take, and roughly what it would cost. No obligation either way.",
        svg: "chatBubble",
        src: personWorking,
        alt: "Photo representing an initial conversation about a project",
        first: true,
      },
      {
        heading: "Design first, then build",
        content:
          "You approve the design before I write a line of code, and you review the full site before it goes live. Feedback and changes are built into the process — that's what the review stages are for.",
        svg: "dashboard",
        src: dashboard,
        alt: "Screen mockup representing the design and build process",
        second: true,
      },
      {
        heading: "Launch and ongoing support",
        content:
          "I handle the launch, walk you through managing the basics yourself, and remain available afterwards. Websites need occasional attention — I don't hand over and disappear.",
        svg: "rocket",
        src: progressBuilding,
        alt: "Photo representing ongoing project support after launch",
      },
    ]}
  />

  <RecentWork title="Recent Work" viewAllUrl="/products" />

  <PricingSection pricing={pricing} />

  <FAQ title="Common Questions" faqs={faqs} />

  <HeroSectionAlt
    title="Got a project in mind?"
    subTitle="Or even just a rough idea. Send me a message and I'll tell you what I'd do with it — no obligation, no hard sell."
    btnTitle="Send me a message"
    url="/contact"
  />
</MainLayout>
