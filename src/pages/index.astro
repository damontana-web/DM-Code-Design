---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import RecentWork from "@components/sections/work/RecentWork.astro";
import CTASection from "@components/sections/pricing/CTASection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import heroImage from "@images/HeroImage.png";
import faqs from "@data/faqs.json";
import features from "@data/features.json";
import pricing from "@data/pricing.json";
import conversationImage from "@images/home-conversation.jpg";
import designBuildImage from "@images/home-design-build.jpg";
import launchImage from "@images/home-launch.jpg";

const pageTitle: string =
  "DaMontana Design + Code | Web Designer & Developer, Melbourne";
const pageDescription: string =
  "Melbourne web designer and developer for small businesses. Design + code by one person, start to finish — no handovers, no agencies.";
---

<MainLayout title={pageTitle} meta={pageDescription}>
  <AnnouncementBanner
    btnId="dismiss-button"
    title="I am currently available for new projects"
    btnTitle="Book a call"
    url="/contact"
  />

  <HeroSection
    title=`<span class="text-magenta-500">{Design}</span> that speaks to your customers <span class="text-blue-primary">+</span> clean <span class="text-blue-primary">{code}</span> that just works.`
    subTitle="Hi, I'm David Montana, a Melbourne designer and developer. For the past 15 years I've built websites for government agencies, healthcare providers, and local businesses across Australia."
    primaryBtn="Book a call"
    primaryBtnURL="/contact"
    secondaryBtn="See my work"
    secondaryBtnURL="/portfolio"
    src={heroImage}
    alt="David Montana - UX/UI Designer and Front-end Developer"
  />

  <FeaturesGeneral
    title="What I Do"
    subTitle="I look after both sides of the fence, the design and the development. There's no handover and no middleman, so what you see in the design is exactly what gets built."
    features={features}
  />

  <FeaturesNavs
    title="How I Work"
    subTitle="I trained inside big advertising agencies and spent years working with digital studios as an external designer and developer. So I run a proper process with clear scope, honest timelines, and no surprises. But most of my clients aren't web people, and they shouldn't have to be. My job is to ask the right questions and explain everything in plain English."
    tabs={[
      {
        heading: "We start with a conversation",
        content:
          "Book a call and tell me about your business — what's working, what isn't, and what you're trying to achieve. I'll give you an honest read on what I'd do, how long it would take, and roughly what it would cost. No obligation either way.",
        svg: "chatBubble",
        headingIcon:
          "M4 18h2v2H4v2H2V4h2v14Zm16 0H6v-2h14v2Zm2-2h-2V4h2v12Zm-12-2H6v-2h4v2Zm4-4H6V8h8v2Zm6-6H4V2h16v2Z",
        src: conversationImage,
        alt: "Photo representing an initial conversation about a project",
        first: true,
      },
      {
        heading: "Design first, then build",
        content:
          "You approve the design before I write a line of code, and you review the full site before it goes live. Feedback and changes are built into the process — that's what the review stages are for.",
        svg: "dashboard",
        headingIcon:
          "M16 20H8v-2h8v2Zm-8-2H4v-2h4v2Zm12 0h-4v-2h4v2ZM4 16H2v-2h2v2Zm10-6h-2v2h2v-2h2v4h-2v2h-4v-2H8v-4h2V8h4v2Zm8 6h-2v-2h2v2ZM2 14H0v-4h2v4Zm22 0h-2v-4h2v4ZM4 10H2V8h2v2Zm18 0h-2V8h2v2ZM8 8H4V6h4v2Zm12 0h-4V6h4v2Zm-4-2H8V4h8v2Z",
        src: designBuildImage,
        alt: "Reviewing email template designs across desktop and mobile",
        second: true,
      },
      {
        heading: "Launch and ongoing support",
        content:
          "I handle the launch, walk you through managing the basics yourself, and stay available afterwards. Websites need occasional attention. I don't hand over and disappear.",
        svg: "rocket",
        headingIcon:
          "M4 20h2v2H2v-4h2v2Zm16 1h-2v-2h2v2Zm-10-1H6v-2h4v2Zm-4-2H4v-4h2v4Zm8 0h-4v-2h4v2Zm-4-2H8v-2h2v2Zm6 0h-2v-4h2v4Zm6 0h-2v-2h2v2ZM8 14H6v-4h2v4Zm12 0h-2v-2h2v2Zm-6-2h-2v-2h2v2Zm-2-2H8V8h4v2Zm8-1h-4V7h4v2ZM5 8H3V6h2v2Zm17-1h-2V5h2v2ZM12 6h-2V4h2v2Zm-2-2H8V2h2v2Zm7 0h-2V2h2v2Z",
        src: launchImage,
        alt: "Photo representing ongoing project support after launch",
      },
    ]}
  />

  <RecentWork title="Recent Work" viewAllUrl="/portfolio" />

  <CTASection pricing={pricing} />

  <FAQ title="Common Questions" faqs={faqs} />

  <HeroSectionAlt
    title="Got a project in mind?"
    subTitle="Or even just a rough idea. Book a call and I'll tell you what I'd do with it — no obligation, no hard sell."
    btnTitle="Book a call"
    url="/contact"
  />
</MainLayout>
